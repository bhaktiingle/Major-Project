<% layout("/layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;

    console.log("Listing data:", listing);
    console.log("Coordinates:", listing.geometry.coordinates);
    
</script>
<div class="row  mt-3">
    <div class="col-md-8 offset-2">
        <h3 class="heading"><%= listing.title %></h3>
    </div>
        <div class="card col-md-6 offset-3 show-card listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing_image">
            <div class="card-body">
                <p class="card-text form-lable">Owned by<i><%= listing.owner ? listing.owner.username : "Anonymous" %></i></p>
                  
                <p class="card-text form-lable"><%= listing.description %>  <br />
                    &#8377; <%= listing.price.toLocaleString("en-IN")  %> <br />
                    <%= listing.location %> <br />
                    <%= listing.country %> <br />

                </p>
            </div> 
        </div>

        <br />
        
<%  if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>

        <div class="btns">
            <div class="d-flex justify-content-center ">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark add-btn col-md-1 offset-2">Edit</a>  
            </div>


        <br /><br />
            <div class="d-flex justify-content-center ">
                <form method="post" action="/listings/<%= listing._id%>?_method=DELETE">
                    <button class="btn add-btn  offset-5">Delete</button>
                </form>
            </div>
        <br /><br />
        <% } %>
    </div>

    
    <div class="col-md-8 offset-2 mb-3">
    <hr />
    <% if(currUser) { %>
    <h4>Leave a Review</h4>
    <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate class="row g-3 needs-validation">
        <div class=" star-rating mt-3">
            <% for (let i = 5; i >= 1; i--) { %>
            <input 
            type="radio" 
            id="star<%= i %>" 
            name="review[rating]" 
            value="<%= i %>"
            class="form-range"
            required/>
            <label for="star<%= i %>" class="form-lable" >★</label>
            <% } %>
        </div>
        <div class="mb-3 mt-3">
            <label for=" comment" class="form-lable">Comments</label>
            <textarea 
            name="review[comment]" 
            id="comment" 
            cols="30" 
            rows="5" 
            class="form-control"
            required
            ></textarea>
        <div class="invalid-feedback">Please add some comments for review</div>
        </div>
        <button class="btn add-btn offset-5">Submit</button>
    </form>
     <hr />
<% } %>
   

    <% if(listing.reviews.length > 0)  { %>
    <div class="row g-4">
    <p><b>All Reviews</b></p>    
     <% for( let review of listing.reviews) { %>
        <div class="card col-5 ms-3 mb-3 border-0 "> 
           <div class="review-card">
            <h5 class="review-title">@<%= review.author.username %></h5>
            <p class="review-text"><%= review.comment %></p>
            <div class="review-rating">
                <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= review.rating) { %>
                    <span class="star filled">★</span>
                    <% } else { %>
                    <span class="star">★</span>
                    <% } %>
                <% } %>
                </div>
                <form class="mb-3 mt-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                     <button class=" btn-sm review-button offset-5">Delete</button>
                </form>
           </div>
        </div>
    <% } %>  
    </div>
    <% } %> 

  </div>
  <div class="col-md-6 offset-3">
        <h3>Where you'll be</h3>
        <div id="map"></div>
<br /><br />
    </div>


</div>
<script src="/js/map.js" ></script>


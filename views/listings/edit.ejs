<% layout("/layouts/boilerplate") %>
<div class="container-new my-5">
<div class="row justify-content-center">
<div class="col-md-8 ">
<div class="form-card">
<br /><br />
<h3 class="heading">Edit your Listing</h3>

    <form method="post"  action="/listings/<%= listing._id %>?_method=PUT" novalidate class="row g-3 needs-validation"
        enctype="multipart/form-data">
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input 
                name="listing[title]" 
                value="<%= listing.title %>" 
                type="text" 
                class="form-control"
                required>
            <div class="valid-feedback">Title looks good</div>
            <div class="invalid-feedback">Please Enter Valid Feedback !</div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-lable">Description</label>
            <textarea 
                name="listing[description]" class="form-control">
                <%= listing.description %>
            </textarea>
            <div class="invalid-feedback">Please Enter a Short Description !</div>
        </div>
    
        <div>
        <label class="form-label">
            Original Listing Image
        </label>
        <br>

        <img 
            src="<%= orignalImageUrl %>" 
            class="img-fluid rounded"
            style="max-width:300px;"
        >
        </div>

        <div>
            <label for="image" class="form-lable">Uplode New Image</label>
            <input 
                name="listing[image][url]"   
                type="file"
                class="form-control"
                >
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-lable">Price</label>
                <input 
                    name="listing[price]" 
                    value="<%= listing.price %>" 
                    class="form-control"
                    required>
                <div class="invalid-feedback">Please Enter Valid Price !</div>     
            </div>
            <div class="mb-3 col-md-8">
                <label for="location" class="form-lable">Location</label>
                <input 
                    name="listing[location]" 
                    value="<%= listing.location %>" 
                    type="text"
                    class="form-control"
                    required>
                    <div class="invalid-feedback">Please Enter Valid Location !</div> 
            </div>
        </div>
        <div>
            <label for="country" class="form-lable">Country</label>
            <input 
                name="listing[country]" 
                value="<%= listing.country %>" 
                type="text"
                class="form-control"
                required> 
            <div class="invalid-feedback">Please Enter Valid Country !</div>
        </div>
        
        <br /><br />
        <div class="d-flex justify-content-center ">
                <button class="btn btn-dark add-btn col-md-2">Edit</button>
            </div>
        <br /><br />
     </form>
    </div>
   </div>
 </div>
</div> 
